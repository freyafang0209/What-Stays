---
---

<div class="newsletter">
  <p class="newsletter-heading">Receive new reflections</p>
  <p class="newsletter-note">No noise. Just a quiet note when something new is written.</p>
  <form class="newsletter-form" data-newsletter>
    <div class="input-wrap">
      <label for="newsletter-email" class="input-label">Email</label>
      <input
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        required
        autocomplete="email"
      />
    </div>
    <button type="submit">Subscribe</button>
  </form>
  <p class="newsletter-thanks" hidden>Thank you. You'll hear from me.</p>
</div>

<script>
  const form = document.querySelector('[data-newsletter]') as HTMLFormElement;
  const thanks = document.querySelector('.newsletter-thanks') as HTMLElement;
  if (form && thanks) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.hidden = true;
      thanks.hidden = false;
    });
  }
</script>

<style>
  .newsletter {
    max-width: 420px;
  }

  .newsletter-heading {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    color: var(--on-surface);
    margin-bottom: var(--space-2);
  }

  .newsletter-note {
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    margin-bottom: var(--space-8);
  }

  .newsletter-form {
    display: flex;
    align-items: flex-end;
    gap: var(--space-4);
  }

  .input-wrap {
    flex: 1;
  }

  .input-label {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--label-md);
    font-weight: 500;
    color: var(--on-surface-variant);
    margin-bottom: var(--space-2);
  }

  .newsletter-form input {
    width: 100%;
    font-family: var(--font-sans);
    font-size: var(--body-md);
    color: var(--on-surface);
    background: var(--surface-container-high);
    border: none;
    border-bottom: 1px solid transparent;
    padding: var(--space-3) var(--space-4);
    outline: none;
    transition: border-color var(--ease-default), background-color var(--ease-default);
  }

  .newsletter-form input::placeholder {
    color: var(--on-surface-variant);
    opacity: 0.5;
  }

  .newsletter-form input:focus {
    border-bottom-color: var(--primary);
    background: var(--surface-container-highest);
  }

  .newsletter-form input:focus + .input-label,
  .newsletter-form input:focus ~ .input-label {
    color: var(--primary);
  }

  .newsletter-form button {
    font-family: var(--font-sans);
    font-size: var(--label-lg);
    font-weight: 500;
    color: var(--on-primary);
    background: var(--primary);
    border: none;
    border-radius: 0.25rem;
    padding: var(--space-3) var(--space-6);
    cursor: pointer;
    white-space: nowrap;
    transition: background-color var(--ease-default);
  }

  .newsletter-form button:hover {
    background: var(--primary-container);
  }

  .newsletter-thanks {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
