---
interface Props {
  date: Date;
}

const { date } = Astro.props;
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<time datetime={date.toISOString()} class="date">{formatted}</time>

<style>
  .date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
