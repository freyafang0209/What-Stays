---
interface Props {
  title: string;
  description?: string;
  fullscreenHero?: boolean;
}

const { title, description = 'A quiet space for noticing the modern mind', fullscreenHero = false } = Astro.props;
const fullTitle = title === 'What Stays' ? title : `${title} — What Stays`;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GQ47GH3GBB"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GQ47GH3GBB');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/Newsreader-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Manrope-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Caveat-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="alternate" type="application/rss+xml" title="What Stays" href="/rss.xml" />
    <title>{fullTitle}</title>
  </head>
  <body class:list={[{ 'fullscreen-hero': fullscreenHero }]}>
    <header class="site-header">
      <nav class="container">
        <a href="/" class="site-name">What Stays</a>
        <div class="nav-links">
          <a href="/articles/">Writings</a>
          <a href="/videos/">Videos</a>
          <a href="/about/">About</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-name">What Stays</span>
        <a href="/rss.xml" class="footer-rss">RSS</a>
      </div>
    </footer>
  </body>
</html>

<style>
  @import '../styles/global.css';

  .site-header {
    padding-block: var(--space-8);
    padding-top: calc(var(--space-8) + env(safe-area-inset-top, 0px));
    padding-left: env(safe-area-inset-left, 0px);
    padding-right: env(safe-area-inset-right, 0px);
  }

  .site-header nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .site-name {
    font-family: var(--font-accent);
    font-size: 1.6rem;
    color: var(--on-surface);
    text-decoration: none;
    transition: color var(--ease-default);
  }

  .site-name:hover {
    color: var(--primary);
  }

  .nav-links {
    display: flex;
    gap: var(--space-8);
  }

  .nav-links a {
    font-family: var(--font-sans);
    font-size: var(--label-lg);
    font-weight: 500;
    color: var(--on-surface-variant);
    text-decoration: none;
    letter-spacing: 0.02em;
    padding-block: var(--space-2);
    transition: color var(--ease-default);
  }

  .nav-links a:hover {
    color: var(--primary);
  }

  main {
    min-height: 60vh;
  }

  /* Footer uses tonal shift, not a border */
  .site-footer {
    margin-top: var(--space-24);
    padding-block: var(--space-10);
    padding-bottom: calc(var(--space-10) + env(safe-area-inset-bottom, 0px));
    padding-left: env(safe-area-inset-left, 0px);
    padding-right: env(safe-area-inset-right, 0px);
    background-color: var(--surface-container-low);
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .footer-name {
    font-family: var(--font-accent);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
  }

  .footer-rss {
    font-size: var(--label-md);
    font-weight: 500;
    color: var(--on-surface-variant);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .footer-rss:hover {
    color: var(--primary);
  }

  /* Fullscreen hero mode: header overlays content, footer loses top margin */
  :global(body.fullscreen-hero) .site-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
  }

  :global(body.fullscreen-hero) .site-footer {
    margin-top: 0;
  }

  :global(body.fullscreen-hero) {
    background-color: transparent;
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .site-header {
      padding-block: var(--space-6);
      padding-top: calc(var(--space-6) + env(safe-area-inset-top, 0px));
    }

    .site-name {
      font-size: 1.35rem;
    }

    .nav-links {
      gap: var(--space-6);
    }

    .nav-links a {
      font-size: var(--label-md);
    }

    .site-footer {
      margin-top: var(--space-16);
      padding-block: var(--space-8);
      padding-bottom: calc(var(--space-8) + env(safe-area-inset-bottom, 0px));
    }

    .footer-name {
      font-size: var(--body-md);
    }
  }
</style>
