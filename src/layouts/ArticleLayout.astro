---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SupportSection from '../components/SupportSection.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  pubDate: Date;
}

const { title, subtitle, description, pubDate } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="article-page">
    <div class="container--narrow">
      <header class="article-header">
        <FormattedDate date={pubDate} />
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </header>

      <div class="prose">
        <slot />
      </div>

      <!-- Breathing pause between content and footer elements -->
      <div class="article-end">
        <svg class="illustration" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M14 18 C14 18, 13 32, 16 34 C19 36, 29 36, 32 34 C35 32, 34 18, 34 18" stroke="var(--outline-variant)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          <path d="M34 22 C36 22, 39 23, 39 26 C39 29, 36 30, 34 30" stroke="var(--outline-variant)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          <path d="M20 14 C20 10, 22 8, 22 8" stroke="var(--outline-variant)" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
          <path d="M26 14 C26 11, 27 9, 27 9" stroke="var(--outline-variant)" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        </svg>
        <SupportSection />
      </div>
    </div>

    <!-- Newsletter on tonal shift -->
    <div class="newsletter-band">
      <div class="container--narrow">
        <NewsletterForm />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding-top: var(--space-16);
  }

  .article-header {
    margin-bottom: var(--space-12);
  }

  .article-header h1 {
    font-family: var(--font-serif);
    font-size: var(--display-md);
    font-weight: 400;
    line-height: var(--leading-display);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    color: var(--on-surface-variant);
    font-style: italic;
    line-height: var(--leading-headline);
  }

  .article-end {
    margin-top: var(--space-20);
    text-align: center;
  }

  .illustration {
    display: block;
    margin-inline: auto;
    margin-bottom: var(--space-10);
    opacity: 0.5;
  }

  .newsletter-band {
    margin-top: var(--space-20);
    padding-block: var(--space-16);
    background-color: var(--surface-container-low);
  }

  @media (max-width: 640px) {
    .article-header h1 {
      font-size: var(--headline-lg);
    }
  }
</style>
