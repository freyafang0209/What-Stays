---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SupportSection from '../components/SupportSection.astro';
import ReaderThoughts from '../components/ReaderThoughts.astro';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  pubDate: Date;
}

const { title, subtitle, description, pubDate } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="article-page">
    <div class="container--narrow">
      <header class="article-header">
        <FormattedDate date={pubDate} />
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </header>

      <div class="prose" id="article-prose">
        <slot />
      </div>

      <!-- Breathing pause between content and footer elements -->
      <div class="article-end">
        <svg class="illustration" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M14 18 C14 18, 13 32, 16 34 C19 36, 29 36, 32 34 C35 32, 34 18, 34 18" stroke="var(--outline-variant)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          <path d="M34 22 C36 22, 39 23, 39 26 C39 29, 36 30, 34 30" stroke="var(--outline-variant)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
          <path d="M20 14 C20 10, 22 8, 22 8" stroke="var(--outline-variant)" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
          <path d="M26 14 C26 11, 27 9, 27 9" stroke="var(--outline-variant)" stroke-width="0.8" stroke-linecap="round" fill="none" opacity="0.5"/>
        </svg>
        <SupportSection />
      </div>
    </div>

    <!-- Reader thoughts -->
    <div class="thoughts-band">
      <div class="container--narrow">
        <ReaderThoughts context="article" />
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .article-page {
    padding-top: var(--space-16);
  }

  .article-page .container--narrow {
    max-width: 720px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 4rem);
  }

  .article-page .article-header {
    max-width: 60ch;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .article-page .article-header h1 {
    font-family: var(--font-serif);
    font-size: var(--display-md);
    font-weight: 400;
    line-height: var(--leading-display);
    margin-top: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .article-page .subtitle {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    color: var(--on-surface-variant);
    font-style: italic;
    line-height: var(--leading-headline);
  }

  .article-page .prose {
    max-width: 60ch;
    margin-inline: auto;
    font-size: var(--body-lg);
    line-height: var(--leading-body);
  }

  .article-page .prose p {
    margin-block: 1.5em;
  }

  .article-page .prose p:first-child {
    margin-top: 0;
  }

  .article-page .article-end {
    margin-top: var(--space-20);
    text-align: center;
  }

  .article-page .illustration {
    display: block;
    margin-inline: auto;
    margin-bottom: var(--space-10);
    opacity: 0.5;
  }

  .article-page .thoughts-band {
    margin-top: var(--space-20);
    padding-block: var(--space-16);
    background-color: var(--surface-container-low);
  }

  /* --- Quiet Reflections reveal --- */
  .article-page .reflection-section {
    margin-top: 3em;
    background-color: var(--surface-container-low);
    padding: var(--space-8) var(--space-8) var(--space-6);
  }

  .article-page .reflection-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--headline-sm);
    color: var(--on-surface);
    margin-bottom: var(--space-4);
  }

  .article-page .reflection-question {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface);
    line-height: var(--leading-body);
    margin-bottom: var(--space-4);
  }

  .article-page .reflection-reveal {
    display: inline-block;
    background: none;
    border: none;
    font-family: var(--font-serif);
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    cursor: pointer;
    letter-spacing: 0.02em;
    padding: var(--space-2) 0;
    min-height: 44px;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .article-page .reflection-reveal:hover {
    opacity: 0.85;
  }

  .article-page .reflection-answer {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.6s ease, opacity 0.5s ease 0.1s;
  }

  .article-page .reflection-answer.revealed {
    max-height: 20em;
    opacity: 1;
  }

  .article-page .reflection-answer p {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
    line-height: var(--leading-body);
    margin-top: var(--space-4);
  }

  @media (max-width: 640px) {
    .article-page {
      padding-top: var(--space-10);
    }

    .article-page .article-header h1 {
      font-size: var(--headline-lg);
    }

    .article-page .article-header {
      margin-bottom: var(--space-8);
    }

    .article-page .prose {
      font-size: 1rem;
      line-height: 1.85;
    }

    .article-page .article-end {
      margin-top: var(--space-12);
    }

    .article-page .thoughts-band {
      margin-top: var(--space-12);
      padding-block: var(--space-10);
    }

    .article-page .reflection-section {
      padding: var(--space-6) var(--space-6) var(--space-4);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const prose = document.getElementById('article-prose');
    if (!prose) return;

    // Find the last <hr> — this precedes "Quiet Reflections"
    const hrs = prose.querySelectorAll('hr');
    if (hrs.length === 0) return;
    const hr = hrs[hrs.length - 1];

    // Collect all siblings after the <hr>
    const siblings: Element[] = [];
    let next = hr.nextElementSibling;
    while (next) {
      siblings.push(next);
      next = next.nextElementSibling;
    }
    if (siblings.length === 0) return;

    // Check if first sibling contains "Quiet Reflections"
    const titleEl = siblings[0];
    if (!titleEl.textContent?.includes('Quiet Reflections')) return;

    // The content paragraph(s) follow the title — split question from answer
    // Question = text up to and including the first "?"
    // Answer = everything after
    const contentEl = siblings[1];
    if (!contentEl) return;

    // Walk through child nodes of the content paragraph to split at "?"
    const questionNodes: Node[] = [];
    const answerNodes: Node[] = [];
    let foundQuestion = false;

    contentEl.childNodes.forEach(node => {
      if (foundQuestion) {
        answerNodes.push(node.cloneNode(true));
        return;
      }
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent || '';
        const qIdx = text.indexOf('?');
        if (qIdx !== -1) {
          questionNodes.push(document.createTextNode(text.slice(0, qIdx + 1)));
          const rest = text.slice(qIdx + 1).replace(/^\s*/, '');
          if (rest) answerNodes.push(document.createTextNode(rest));
          foundQuestion = true;
        } else {
          questionNodes.push(node.cloneNode(true));
        }
      } else {
        // <br> or other elements
        if (!foundQuestion) {
          questionNodes.push(node.cloneNode(true));
        } else {
          answerNodes.push(node.cloneNode(true));
        }
      }
    });

    // Also gather any additional content paragraphs as answer content
    const extraAnswerEls = siblings.slice(2);

    // Remove original elements from DOM
    hr.remove();
    siblings.forEach(el => el.remove());

    // Build the reflection section
    const section = document.createElement('div');
    section.className = 'reflection-section';

    const title = document.createElement('p');
    title.className = 'reflection-title';
    title.textContent = 'Quiet Reflections';

    const question = document.createElement('p');
    question.className = 'reflection-question';
    questionNodes.forEach(n => question.appendChild(n));

    const btn = document.createElement('button');
    btn.className = 'reflection-reveal';
    btn.textContent = 'Pause and reflect';
    btn.setAttribute('aria-expanded', 'false');

    const answer = document.createElement('div');
    answer.className = 'reflection-answer';
    if (answerNodes.length > 0) {
      // Strip leading <br> nodes
      while (answerNodes.length && answerNodes[0].nodeName === 'BR') {
        answerNodes.shift();
      }
      const answerP = document.createElement('p');
      answerNodes.forEach(n => answerP.appendChild(n));
      answer.appendChild(answerP);
    }
    extraAnswerEls.forEach(el => answer.appendChild(el));

    btn.addEventListener('click', () => {
      answer.classList.add('revealed');
      btn.style.opacity = '0';
      btn.style.pointerEvents = 'none';
      btn.setAttribute('aria-expanded', 'true');
    });

    section.appendChild(title);
    section.appendChild(question);
    section.appendChild(btn);
    section.appendChild(answer);
    prose.appendChild(section);
  });
</script>
