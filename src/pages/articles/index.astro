---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writings" description="All writings from What Stays.">
  <section class="page container">
    <h1>Writings</h1>

    <ul class="article-list">
      {sorted.map(article => (
        <li>
          <a href={`/articles/${article.id}/`} class="article-link">
            <span class="article-title">{article.data.title}</span>
            <span class="article-date"><FormattedDate date={article.data.pubDate} /></span>
          </a>
          <p class="article-description">{article.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: 6rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: 400;
    max-width: var(--measure);
    margin-inline: auto;
    margin-bottom: 4rem;
  }

  .article-list {
    list-style: none;
    max-width: var(--measure);
    margin-inline: auto;
  }

  .article-list li {
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    margin-bottom: 0.3rem;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: color 0.2s;
  }

  .article-link:hover .article-title {
    color: var(--color-accent);
  }

  .article-date {
    flex-shrink: 0;
  }

  .article-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }
</style>
