---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writings" description="All writings from What Stays.">
  <section class="page">
    <div class="container">
      <h1>Writings</h1>

      <ul class="article-list">
        {sorted.map(article => (
          <li class="article-item">
            <a href={`/articles/${article.id}/`} class="article-link">
              <span class="article-title">{article.data.title}</span>
              <span class="article-meta"><FormattedDate date={article.data.pubDate} /></span>
            </a>
            <p class="article-description">{article.data.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    font-weight: 400;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .article-list {
    list-style: none;
    max-width: 600px;
    margin-inline: auto;
  }

  .article-item {
    padding-block: var(--space-6);
  }

  .article-item + .article-item {
    background-image: linear-gradient(var(--surface-container), var(--surface-container));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: top;
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    text-decoration: none;
    margin-bottom: var(--space-1);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface);
    transition: color var(--ease-default);
  }

  .article-link:hover .article-title {
    color: var(--primary);
  }

  .article-meta {
    flex-shrink: 0;
  }

  .article-description {
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    line-height: 1.6;
    max-width: 50ch;
  }

  @media (max-width: 640px) {
    .page {
      padding-top: var(--space-16);
      padding-bottom: var(--space-10);
    }

    h1 {
      margin-bottom: var(--space-8);
    }

    .article-link {
      flex-direction: column;
      gap: var(--space-1);
    }

    .article-description {
      font-size: var(--label-md);
      line-height: 1.5;
    }
  }
</style>
