---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Add YouTube video IDs and titles here (newest last)
const videos: { id: string; title: string }[] = [
  { id: 'IUVBudAYI9c', title: 'Why Does Happiness Feel So Short-Lived?' },
  { id: 'CSdTX-k678s', title: 'You Rest, but Your Mind Stays at Work' },
];

const reversed = [...videos].reverse();
const useStrip = reversed.length >= 3;
const featured = reversed[0];
const others = reversed.slice(1);
---

<BaseLayout title="Videos" description="Video reflections from What Stays.">
  <section class="page">
    <div class="container videos-layout">
      <h1>Videos</h1>

      {videos.length === 0 && (
        <p class="empty-state">Coming soon.</p>
      )}

      {/* Simple stacked layout for 1-2 videos */}
      {!useStrip && reversed.length > 0 && (
        <div class="video-list">
          {reversed.map(video => (
            <div class="video-item">
              <div class="video-embed">
                <button
                  class="video-poster"
                  data-id={video.id}
                  aria-label={`Play ${video.title}`}
                >
                  <img
                    src={`https://img.youtube.com/vi/${video.id}/hqdefault.jpg`}
                    alt={video.title}
                    loading="lazy"
                  />
                  <span class="play-btn" aria-hidden="true">
                    <svg viewBox="0 0 68 48" width="68" height="48">
                      <path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="rgba(0,0,0,0.7)"/>
                      <path d="M45 24L27 14v20" fill="#fff"/>
                    </svg>
                  </span>
                </button>
              </div>
              <h2 class="video-title">{video.title}</h2>
            </div>
          ))}
        </div>
      )}

      {/* Featured + thumbnail strip for 3+ videos */}
      {useStrip && (
        <div class="featured" id="featured">
          <div class="video-embed">
            <iframe
              id="featured-iframe"
              src={`https://www.youtube.com/embed/${featured.id}`}
              title={featured.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
          <h2 class="featured-title" id="featured-title">{featured.title}</h2>
        </div>
      )}

      {useStrip && others.length > 0 && (
        <div class="strip-section">
          <div class="strip" id="strip">
            {others.map(video => (
              <button
                class="strip-item"
                data-id={video.id}
                data-title={video.title}
              >
                <img
                  src={`https://img.youtube.com/vi/${video.id}/mqdefault.jpg`}
                  alt={video.title}
                  loading="lazy"
                />
                <span class="strip-title">{video.title}</span>
              </button>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  // Lite YouTube: load iframe only when poster is tapped
  document.querySelectorAll('.video-poster').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id;
      const embed = btn.parentElement!;
      embed.innerHTML = `<iframe
        src="https://www.youtube.com/embed/${id}?autoplay=1"
        title=""
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />`;
    });
  });

  const strip = document.getElementById('strip');
  const iframe = document.getElementById('featured-iframe') as HTMLIFrameElement;
  const title = document.getElementById('featured-title');
  if (strip && iframe && title) {
    // Track current featured video
    let currentId = new URL(iframe.src).pathname.split('/').pop() || '';

    strip.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.strip-item') as HTMLElement;
      if (!btn) return;

      const newId = btn.dataset.id!;
      const newTitle = btn.dataset.title!;

      // Swap: put current featured into this thumbnail slot
      const oldId = currentId;
      const oldTitle = title.textContent || '';

      // Update featured
      iframe.src = `https://www.youtube.com/embed/${newId}`;
      iframe.title = newTitle;
      title.textContent = newTitle;
      currentId = newId;

      // Update the clicked thumbnail to show the old featured
      btn.dataset.id = oldId;
      btn.dataset.title = oldTitle;
      const img = btn.querySelector('img')!;
      img.src = `https://img.youtube.com/vi/${oldId}/mqdefault.jpg`;
      img.alt = oldTitle;
      const span = btn.querySelector('.strip-title')!;
      span.textContent = oldTitle;
    });
  }
</script>

<style>
  .page {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
  }

  .videos-layout {
    max-width: 720px;
    margin-inline: auto;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    font-weight: 400;
    margin-bottom: var(--space-12);
  }

  .empty-state {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
  }

  /* Stacked layout (1-2 videos) */
  .video-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .video-title {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    font-weight: 400;
    margin-top: var(--space-4);
  }

  /* Featured video */
  .featured {
    margin-bottom: var(--space-12);
  }

  .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    background-color: var(--surface-container);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    margin: 0;
    background: none;
    cursor: pointer;
    -webkit-tap-highlight-color: rgba(107, 130, 148, 0.15);
  }

  .video-poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease;
  }

  .video-poster:hover .play-btn {
    opacity: 0.85;
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    font-weight: 400;
    margin-top: var(--space-4);
  }

  /* Thumbnail strip */
  .strip-section {
    margin-top: var(--space-8);
  }

  .strip {
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: var(--space-2);
  }

  .strip::-webkit-scrollbar {
    display: none;
  }

  .strip-item {
    flex: 0 0 auto;
    width: 200px;
    scroll-snap-align: start;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    transition: opacity 0.2s ease;
    -webkit-tap-highlight-color: rgba(107, 130, 148, 0.15);
  }

  .strip-item:hover {
    opacity: 0.8;
  }

  .strip-item img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background-color: var(--surface-container);
    border-radius: 2px;
  }

  .strip-title {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--body-sm);
    color: var(--on-surface-variant);
    margin-top: var(--space-2);
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .page {
      padding-top: var(--space-16);
      padding-bottom: var(--space-10);
    }

    h1 {
      margin-bottom: var(--space-8);
    }

    /* Stacked layout on mobile */
    .video-list {
      gap: var(--space-12);
      margin-inline: calc(-1 * clamp(2rem, 6vw, 5rem));
    }

    .video-title {
      font-size: var(--body-lg);
      padding-inline: clamp(2rem, 6vw, 5rem);
    }

    /* Featured video goes edge-to-edge */
    .featured {
      margin-bottom: var(--space-8);
      margin-inline: calc(-1 * clamp(2rem, 6vw, 5rem));
    }

    .featured-title {
      font-size: var(--body-lg);
      padding-inline: clamp(2rem, 6vw, 5rem);
    }

    /* Thumbnail strip goes edge-to-edge with inset padding */
    .strip-section {
      margin-inline: calc(-1 * clamp(2rem, 6vw, 5rem));
    }

    .strip {
      padding-inline: clamp(2rem, 6vw, 5rem);
      gap: var(--space-3);
      scroll-padding-inline-start: clamp(2rem, 6vw, 5rem);
    }

    /* Larger touch targets on mobile */
    .strip-item {
      width: 180px;
      min-height: 44px;
    }

    .strip-title {
      font-size: var(--body-sm);
      padding-top: var(--space-1, 0.25rem);
    }
  }
</style>
