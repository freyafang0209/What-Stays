---
import BaseLayout from '../layouts/BaseLayout.astro';
import SupportSection from '../components/SupportSection.astro';
---

<BaseLayout title="About" description="About What Stays — a quiet space for noticing the modern mind.">
  <section class="page">
    <img src="/images/about-bg.jpeg" alt="" class="about-bg" aria-hidden="true" />
    <div class="container about-layout">
      <div class="about-content">
        <h1>About</h1>

        <div class="prose">
          <p>
            Some thoughts don't pass as quickly as we expect.<br/>
            They stay quietly.
          </p>

          <p>
            In the background of our days,<br/>
            in the way we hesitate,<br/>
            in the way certain feelings return without asking.
          </p>

          <p class="section-break">
            Here, writing dwells on subtle psychological experiences in modern life.
          </p>

          <p>
            Rather than offering advice or quick solutions,<br/>
            it lingers on the quiet mental patterns that often go unnoticed.<br/>
            the thoughts that stay,<br/>
            the internal noise that persists,<br/>
            and the subtle ways modern life shapes how we perceive<br/>
            work, rest, relationships, and responsibility.
          </p>

          <p class="section-break">
            Not to instruct.<br/>
            Not to diagnose.
          </p>

          <p>
            Only to notice.
          </p>

          <p>
            And perhaps,<br/>
            to make these experiences feel a little less yours alone.
          </p>
        </div>

        <div class="support-wrap">
          <SupportSection />
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .page {
    position: relative;
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
    min-height: 100vh;
    min-height: 100svh;
  }

  .about-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.2;
    z-index: 0;
  }

  .about-layout {
    position: relative;
    z-index: 1;
    display: flex;
    gap: var(--space-16);
    align-items: flex-start;
    justify-content: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .about-content {
    flex: 1;
    max-width: var(--measure);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    font-weight: 400;
    margin-bottom: var(--space-12);
  }


  .support-wrap {
    margin-top: var(--space-16);
  }

  .section-break {
    margin-top: var(--space-10);
  }

  @media (max-width: 768px) {
    .about-layout {
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding-top: var(--space-10);
      padding-bottom: var(--space-10);
    }

    h1 {
      margin-bottom: var(--space-6);
    }

    .prose {
      font-size: 1rem;
      line-height: 1.85;
    }

    .section-break {
      margin-top: var(--space-8);
    }

    .support-wrap {
      margin-top: var(--space-10);
    }
  }
</style>
