---
import BaseLayout from '../layouts/BaseLayout.astro';
import SupportSection from '../components/SupportSection.astro';
---

<BaseLayout title="About" description="About What Stays — a quiet space for noticing the modern mind.">
  <section class="page">
    <div class="container about-layout">
      <div class="about-content">
        <h1>About</h1>

        <div class="prose">
          <p>
            Some thoughts don't pass as quickly as we expect.
          </p>

          <p>
            They stay —<br/>
            quietly,<br/>
            in the background of our days,<br/>
            in the way we hesitate,<br/>
            in the way certain feelings return without asking.
          </p>

          <p class="section-break">
            Here, writing dwells on subtle psychological experiences in modern life.
          </p>

          <p>
            Rather than offering advice or quick solutions,<br/>
            it lingers on the quiet mental patterns that often go unnoticed —<br/>
            the thoughts that stay,<br/>
            the internal noise that persists,<br/>
            and the subtle ways modern life shapes how we perceive<br/>
            work, rest, relationships, and responsibility.
          </p>

          <p class="section-break">
            Not to instruct.<br/>
            Not to diagnose.
          </p>

          <p>
            Only to notice.
          </p>

          <p>
            And perhaps,<br/>
            to make these experiences feel a little less yours alone.
          </p>
        </div>

        <div class="support-wrap">
          <SupportSection />
        </div>
      </div>

      <!-- Offset illustration — asymmetric, per editorial rule -->
      <aside class="about-aside">
        <svg width="64" height="80" viewBox="0 0 64 80" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="10" y="8" width="44" height="56" rx="1" stroke="var(--outline-variant)" stroke-width="1" fill="none"/>
          <line x1="32" y1="8" x2="32" y2="64" stroke="var(--outline-variant)" stroke-width="0.6"/>
          <line x1="10" y1="36" x2="54" y2="36" stroke="var(--outline-variant)" stroke-width="0.6"/>
          <path d="M16 42 L16 58 L28 58 L28 42" stroke="var(--outline-variant)" stroke-width="0.5" fill="none" opacity="0.25"/>
          <line x1="24" y1="68" x2="40" y2="68" stroke="var(--outline-variant)" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .page {
    padding-top: var(--space-20);
    padding-bottom: var(--space-16);
  }

  .about-layout {
    display: flex;
    gap: var(--space-16);
    align-items: flex-start;
    justify-content: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .about-content {
    flex: 1;
    max-width: var(--measure);
  }

  h1 {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    font-weight: 400;
    margin-bottom: var(--space-12);
  }

  .about-aside {
    flex-shrink: 0;
    padding-top: var(--space-24);
    opacity: 0.4;
  }

  .support-wrap {
    margin-top: var(--space-16);
  }

  .section-break {
    margin-top: var(--space-10);
  }

  @media (max-width: 768px) {
    .about-layout {
      flex-direction: column;
    }

    .about-aside {
      padding-top: 0;
      align-self: center;
    }
  }
</style>
