---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.find(a => a.data.featured);
const recent = sorted.filter(a => a !== featured).slice(0, 4);
---

<BaseLayout title="What Stays" fullscreenHero>
  <!-- Atmosphere -->
  <div class="bg-ambient" aria-hidden="true"></div>
  <svg class="grain" aria-hidden="true" preserveAspectRatio="none">
    <filter id="grain-filter">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#grain-filter)"/>
  </svg>

  <!-- Screen 1: Hero — illustrated cliffs backdrop -->
  <section class="snap-section hero">
    <img src="/images/hero-cliffs.png" alt="" class="hero-bg" aria-hidden="true" />
    <div class="hero-content">
      <h1 class="hero-title">What Stays</h1>
      <hr class="hero-rule" />
      <p class="hero-subtitle">A quiet space for the thoughts that linger.</p>
    </div>
    <svg class="hero-sparkle" width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
      <path d="M14 0 C14.5 9 19 13.5 28 14 C19 14.5 14.5 19 14 28 C13.5 19 9 14.5 0 14 C9 13.5 13.5 9 14 0Z" fill="rgba(255,255,255,0.6)"/>
    </svg>
    <div class="scroll-hint" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 7l6 6 6-6"/>
      </svg>
    </div>
  </section>

  <!-- Screen 2: Philosophy -->
  <section class="snap-section philosophy">
    <div class="philosophy-inner">
      <blockquote class="philosophy-quote">
        Between the urgent and the forgotten,<br/>
        there is a quieter place.
      </blockquote>
      <div class="philosophy-illustration">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="8" y="8" width="22" height="28" rx="1" stroke="var(--outline-variant)" stroke-width="1" fill="none"/>
          <line x1="8" y1="22" x2="30" y2="22" stroke="var(--outline-variant)" stroke-width="0.7"/>
          <line x1="19" y1="8" x2="19" y2="36" stroke="var(--outline-variant)" stroke-width="0.7"/>
          <path d="M36 32 C36 28, 38 26, 42 26 C46 26, 48 28, 48 32 L48 42 L36 42 Z" stroke="var(--outline-variant)" stroke-width="1" fill="none"/>
          <line x1="36" y1="42" x2="34" y2="48" stroke="var(--outline-variant)" stroke-width="1" stroke-linecap="round"/>
          <line x1="48" y1="42" x2="50" y2="48" stroke="var(--outline-variant)" stroke-width="1" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Screen 3: Manifesto -->
  <section class="snap-section manifesto">
    <div class="manifesto-content">
      <p class="manifesto-text">
        Some things pass through us —<br/>
        news, noise, the scroll of days.<br/>
        And some things stay.
      </p>
      <p class="manifesto-coda">This is a place for the things that stay.</p>
    </div>
  </section>

  <!-- Featured article -->
  {featured && (
    <section class="featured-section">
      <div class="container">
        <a href={`/articles/${featured.id}/`} class="featured-card">
          <span class="featured-label">Featured</span>
          <h2 class="featured-title">{featured.data.title}</h2>
          {featured.data.subtitle && <p class="featured-subtitle">{featured.data.subtitle}</p>}
          <p class="featured-description">{featured.data.description}</p>
          <FormattedDate date={featured.data.pubDate} />
        </a>
      </div>
    </section>
  )}

  <!-- Recent articles -->
  <section class="recent-section">
    <div class="container">
      <h2 class="section-heading">Recent</h2>
      <ul class="article-list">
        {recent.map(article => (
          <li class="article-item">
            <a href={`/articles/${article.id}/`} class="article-link">
              <span class="article-title">{article.data.title}</span>
              <span class="article-meta"><FormattedDate date={article.data.pubDate} /></span>
            </a>
            <p class="article-description">{article.data.description}</p>
          </li>
        ))}
      </ul>
      <a href="/articles/" class="see-all">All writings</a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter-section">
    <div class="container">
      <NewsletterForm />
    </div>
  </section>
</BaseLayout>

<style is:global>
  html {
    scroll-snap-type: y proximity;
    background-color: #FBFBFB;
  }
</style>

<style>
  /* --- Atmosphere --- */
  .grain {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    opacity: 0.03;
    pointer-events: none;
  }

  .bg-ambient {
    background-color: var(--bg-base);
    background-image:
      radial-gradient(at 0% 0%, var(--glow-1) 0px, transparent 50%),
      radial-gradient(at 100% 100%, var(--glow-2) 0px, transparent 50%);
    filter: blur(80px);
    opacity: 0.6;
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  /* --- Scroll Snap Sections --- */
  .snap-section {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    scroll-snap-align: start;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* --- Hero --- */
  .hero {
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-accent);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 400;
    color: var(--on-surface);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero-rule {
    width: 3rem;
    height: 1px;
    border: none;
    background-color: var(--on-surface-variant);
    margin: var(--space-6) auto;
    opacity: 0.4;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
    line-height: var(--leading-body);
  }

  .hero-sparkle {
    position: absolute;
    bottom: var(--space-10);
    right: var(--space-10);
    z-index: 1;
    opacity: 0;
    animation: sparkle-in 2s ease 1.5s forwards;
  }

  @keyframes sparkle-in {
    to { opacity: 1; }
  }

  .scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255, 255, 255, 0.5);
    opacity: 0;
    animation: fade-in 1.5s ease 2s forwards, float 3s ease-in-out 3.5s infinite;
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* --- Philosophy --- */
  .philosophy {
    background-color: rgba(246, 243, 236, 0.7);
  }

  .philosophy-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-16);
    padding-inline: var(--space-8);
  }

  .philosophy-quote {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    line-height: var(--leading-headline);
    color: var(--on-surface);
    border: none;
    padding: 0;
    margin: 0;
  }

  .philosophy-illustration {
    flex-shrink: 0;
    opacity: 0.45;
  }

  /* --- Manifesto --- */
  .manifesto-content {
    text-align: center;
    padding-inline: var(--space-8);
    max-width: 560px;
  }

  .manifesto-text {
    font-family: var(--font-serif);
    font-size: var(--headline-md);
    line-height: var(--leading-headline);
    color: var(--on-surface);
    margin-bottom: var(--space-8);
  }

  .manifesto-coda {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
  }

  /* --- Featured --- */
  .featured-section {
    padding-block: var(--space-16);
  }

  .featured-card {
    display: block;
    text-decoration: none;
    background: var(--surface-container-lowest);
    padding: var(--space-10);
    max-width: 600px;
    margin-inline: auto;
    transition: box-shadow var(--ease-default);
  }

  .featured-card:hover {
    box-shadow: 0 8px 40px -10px rgba(28, 27, 24, 0.06);
  }

  .featured-label {
    font-family: var(--font-sans);
    font-size: var(--label-sm);
    font-weight: 600;
    color: var(--primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: var(--space-4);
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    font-weight: 400;
    color: var(--on-surface);
    margin-bottom: var(--space-2);
    transition: color var(--ease-default);
  }

  .featured-card:hover .featured-title {
    color: var(--primary);
  }

  .featured-subtitle {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
    margin-bottom: var(--space-4);
  }

  .featured-description {
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    margin-bottom: var(--space-4);
    max-width: 50ch;
  }

  /* --- Recent --- */
  .recent-section {
    padding-block: var(--space-16);
    background-color: var(--surface-container-low);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    font-weight: 400;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .article-list {
    list-style: none;
    max-width: 600px;
    margin-inline: auto;
  }

  .article-item {
    padding-block: var(--space-6);
  }

  .article-item + .article-item {
    background-image: linear-gradient(var(--surface-container), var(--surface-container));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: top;
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    text-decoration: none;
    margin-bottom: var(--space-1);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface);
    transition: color var(--ease-default);
  }

  .article-link:hover .article-title {
    color: var(--primary);
  }

  .article-meta {
    flex-shrink: 0;
  }

  .article-description {
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    line-height: 1.6;
    max-width: 50ch;
  }

  .see-all {
    display: block;
    max-width: 600px;
    margin-inline: auto;
    margin-top: var(--space-8);
    font-family: var(--font-sans);
    font-size: var(--label-lg);
    font-weight: 500;
    color: var(--primary);
    letter-spacing: 0.02em;
    transition: color var(--ease-default);
  }

  .see-all:hover {
    color: var(--primary-container);
  }

  /* --- Newsletter --- */
  .newsletter-section {
    padding-block: var(--space-20);
  }

  .newsletter-section .container {
    display: flex;
    justify-content: center;
  }

  /* --- Responsive --- */
  @media (max-width: 640px) {
    .hero-sparkle {
      bottom: var(--space-8);
      right: var(--space-8);
    }

    .philosophy-inner {
      flex-direction: column;
      gap: var(--space-8);
    }

    .philosophy-quote {
      font-size: var(--headline-md);
    }

    .manifesto-text {
      font-size: var(--headline-sm);
    }

    .featured-card {
      padding: var(--space-8);
    }

    .article-link {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
