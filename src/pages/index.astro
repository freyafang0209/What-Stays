---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.find(a => a.data.featured);
const recent = sorted.filter(a => a !== featured).slice(0, 4);
---

<BaseLayout title="What Stays">
  <section class="hero container">
    <h1 class="site-title">What Stays</h1>
    <p class="tagline">A quiet space for noticing the modern mind</p>
    <p class="intro">
      Some things pass through us — news, noise, the scroll of days.
      And some things stay. This is a place for the things that stay.
    </p>
  </section>

  <section class="transition container">
    <p class="transition-text">
      Between the urgent and the forgotten,<br />
      there is a quieter place.
    </p>

    <!-- Small illustration: empty chair by a window -->
    <svg class="illustration" width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="8" y="8" width="22" height="28" rx="1" stroke="var(--color-illustration)" stroke-width="1" fill="none"/>
      <line x1="8" y1="22" x2="30" y2="22" stroke="var(--color-illustration)" stroke-width="0.7"/>
      <line x1="19" y1="8" x2="19" y2="36" stroke="var(--color-illustration)" stroke-width="0.7"/>
      <path d="M36 32 C36 28, 38 26, 42 26 C46 26, 48 28, 48 32 L48 42 L36 42 Z" stroke="var(--color-illustration)" stroke-width="1" fill="none"/>
      <line x1="36" y1="42" x2="34" y2="48" stroke="var(--color-illustration)" stroke-width="1" stroke-linecap="round"/>
      <line x1="48" y1="42" x2="50" y2="48" stroke="var(--color-illustration)" stroke-width="1" stroke-linecap="round"/>
    </svg>
  </section>

  {featured && (
    <section class="featured container">
      <a href={`/articles/${featured.id}/`} class="featured-link">
        <h2>{featured.data.title}</h2>
        {featured.data.subtitle && <p class="featured-subtitle">{featured.data.subtitle}</p>}
        <p class="featured-description">{featured.data.description}</p>
        <FormattedDate date={featured.data.pubDate} />
      </a>
    </section>
  )}

  <section class="recent container">
    <h2 class="section-heading">Recent</h2>
    <ul class="article-list">
      {recent.map(article => (
        <li>
          <a href={`/articles/${article.id}/`} class="article-link">
            <span class="article-title">{article.data.title}</span>
            <span class="article-date"><FormattedDate date={article.data.pubDate} /></span>
          </a>
          <p class="article-description">{article.data.description}</p>
        </li>
      ))}
    </ul>
    <a href="/articles/" class="see-all">See all writings</a>
  </section>

  <NewsletterForm />
</BaseLayout>

<style>
  .hero {
    padding-top: 8rem;
    padding-bottom: 2rem;
    text-align: center;
  }

  .site-title {
    font-family: var(--font-accent);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .intro {
    max-width: 42ch;
    margin-inline: auto;
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: var(--leading-body);
  }

  .transition {
    padding-block: 6rem;
    text-align: center;
  }

  .transition-text {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    font-style: italic;
    line-height: var(--leading-relaxed);
    margin-bottom: 3rem;
  }

  .illustration {
    display: block;
    margin-inline: auto;
    opacity: 0.6;
  }

  .featured {
    padding-bottom: 4rem;
  }

  .featured-link {
    display: block;
    max-width: var(--measure);
    margin-inline: auto;
    text-decoration: none;
    padding: 2rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .featured-link:hover h2 {
    color: var(--color-accent);
  }

  .featured-link h2 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    transition: color 0.2s;
  }

  .featured-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0.8rem;
  }

  .featured-description {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: 0.8rem;
  }

  .recent {
    padding-bottom: 2rem;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: 400;
    max-width: var(--measure);
    margin-inline: auto;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .article-list {
    list-style: none;
    max-width: var(--measure);
    margin-inline: auto;
  }

  .article-list li {
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    text-decoration: none;
    margin-bottom: 0.3rem;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: color 0.2s;
  }

  .article-link:hover .article-title {
    color: var(--color-accent);
  }

  .article-date {
    flex-shrink: 0;
  }

  .article-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .see-all {
    display: block;
    max-width: var(--measure);
    margin-inline: auto;
    margin-top: 2rem;
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  .see-all:hover {
    color: var(--color-accent-hover);
  }
</style>
