---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = sorted.slice(0, 3);
---

<BaseLayout title="What Stays" fullscreenHero>
  <!-- Atmosphere -->
  <div class="bg-ambient" aria-hidden="true"></div>
  <svg class="grain" aria-hidden="true" preserveAspectRatio="none">
    <filter id="grain-filter">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#grain-filter)"/>
  </svg>

  <!-- Screen 1: Hero — illustrated cliffs backdrop -->
  <section class="snap-section hero">
    <img src="/images/hero-cliffs.jpeg" alt="" class="hero-bg" aria-hidden="true" />
    <div class="hero-content">
      <h1 class="hero-title">What Stays</h1>
      <hr class="hero-rule" />
      <p class="hero-subtitle"><strong>A quiet space for noticing the modern mind.</strong></p>
    </div>
    <svg class="hero-sparkle" width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
      <path d="M14 0 C14.5 9 19 13.5 28 14 C19 14.5 14.5 19 14 28 C13.5 19 9 14.5 0 14 C9 13.5 13.5 9 14 0Z" fill="rgba(255,255,255,0.6)"/>
    </svg>
    <div class="scroll-hint" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 7l6 6 6-6"/>
      </svg>
    </div>
  </section>

  <!-- Screen 2: Philosophy -->
  <section class="snap-section philosophy">
    <div class="philosophy-inner">
      <p class="philosophy-text">
        Some patterns are quiet.<br/>
        Some feelings stay longer than they should.<br/>
        Some thoughts return without asking.
      </p>
    </div>
  </section>

  <!-- Screen 3: Manifesto -->
  <section class="snap-section manifesto">
    <img src="/images/manifesto-bg.jpeg" alt="" class="manifesto-bg" aria-hidden="true" />
    <div class="manifesto-content">
      <p class="manifesto-text">
        No advice.<br/>
        No diagnosis.
      </p>
      <p class="manifesto-coda">Just a place to notice what stays.</p>
    </div>
  </section>

  <!-- Recent articles -->
  <section class="recent-section">
    <div class="container">
      <h2 class="section-heading">Recent</h2>
      <ul class="article-list">
        {recent.map(article => (
          <li class="article-item">
            <a href={`/articles/${article.id}/`} class="article-link">
              <span class="article-title">{article.data.title}</span>
              <span class="article-meta"><FormattedDate date={article.data.pubDate} /></span>
            </a>
            <p class="article-description">{article.data.description}</p>
          </li>
        ))}
      </ul>
      <a href="/articles/" class="see-all">All writings</a>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter-section">
    <div class="container">
      <NewsletterForm />
    </div>
  </section>
</BaseLayout>

<style is:global>
  html {
    scroll-snap-type: y proximity;
    background-color: var(--bg-base);
  }
</style>

<style>
  /* --- Atmosphere --- */
  .grain {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    opacity: 0.03;
    pointer-events: none;
  }

  .bg-ambient {
    background-color: var(--bg-base);
    background-image:
      radial-gradient(at 0% 0%, var(--glow-1) 0px, transparent 50%),
      radial-gradient(at 100% 100%, var(--glow-2) 0px, transparent 50%);
    filter: blur(80px);
    opacity: 0.6;
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  /* --- Scroll Snap Sections --- */
  .snap-section {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    scroll-snap-align: start;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* --- Hero --- */
  .hero {
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-title {
    font-family: var(--font-accent);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 400;
    color: var(--on-surface);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .hero-rule {
    width: 3rem;
    height: 1px;
    border: none;
    background-color: var(--on-surface-variant);
    margin: var(--space-6) auto;
    opacity: 0.4;
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
    line-height: var(--leading-body);
  }

  .hero-sparkle {
    position: absolute;
    bottom: var(--space-10);
    right: var(--space-10);
    z-index: 1;
    opacity: 0;
    animation: sparkle-in 2s ease 1.5s forwards;
  }

  @keyframes sparkle-in {
    to { opacity: 1; }
  }

  .scroll-hint {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255, 255, 255, 0.5);
    opacity: 0;
    animation: fade-in 1.5s ease 2s forwards, float 3s ease-in-out 3.5s infinite;
  }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* --- Philosophy --- */
  .philosophy {
    background-color: rgba(228, 230, 234, 0.7);
  }

  .philosophy-inner {
    text-align: center;
    padding-inline: var(--space-8);
  }

  .philosophy-text {
    font-family: var(--font-serif);
    font-size: var(--headline-lg);
    line-height: var(--leading-headline);
    color: var(--on-surface);
  }

  /* --- Manifesto --- */
  .manifesto {
    overflow: hidden;
  }

  .manifesto-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .manifesto-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-inline: var(--space-8);
    max-width: 560px;
  }

  .manifesto-text {
    font-family: var(--font-serif);
    font-size: var(--headline-md);
    line-height: var(--leading-headline);
    color: var(--on-surface);
    margin-bottom: var(--space-8);
  }

  .manifesto-coda {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface-variant);
    font-style: italic;
  }

  /* --- Recent --- */
  .recent-section {
    padding-block: var(--space-16);
    background-color: var(--surface-container-low);
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: var(--headline-sm);
    font-weight: 400;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .article-list {
    list-style: none;
    max-width: 600px;
    margin-inline: auto;
  }

  .article-item {
    padding-block: var(--space-6);
  }

  .article-item + .article-item {
    background-image: linear-gradient(var(--surface-container), var(--surface-container));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: top;
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    text-decoration: none;
    margin-bottom: var(--space-1);
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: var(--body-lg);
    color: var(--on-surface);
    transition: color var(--ease-default);
  }

  .article-link:hover .article-title {
    color: var(--primary);
  }

  .article-meta {
    flex-shrink: 0;
  }

  .article-description {
    font-size: var(--body-md);
    color: var(--on-surface-variant);
    line-height: 1.6;
    max-width: 50ch;
  }

  .see-all {
    display: block;
    max-width: 600px;
    margin-inline: auto;
    margin-top: var(--space-8);
    font-family: var(--font-sans);
    font-size: var(--label-lg);
    font-weight: 500;
    color: var(--primary);
    letter-spacing: 0.02em;
    transition: color var(--ease-default);
  }

  .see-all:hover {
    color: var(--primary-container);
  }

  /* --- Newsletter --- */
  .newsletter-section {
    padding-block: var(--space-20);
  }

  .newsletter-section .container {
    display: flex;
    justify-content: center;
  }

  /* --- Responsive --- */
  @media (max-width: 640px) {
    /* Hero: stacked layout — image on top, content below */
    .hero {
      flex-direction: column;
      justify-content: flex-start;
      background-color: #dfe3e8;
    }

    .hero-bg {
      position: relative;
      height: auto;
      width: 100%;
      flex-shrink: 0;
      object-fit: contain;
      object-position: top center;
    }

    .hero-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-inline: var(--space-8);
    }

    .hero-sparkle {
      bottom: var(--space-8);
      right: var(--space-6);
      width: 22px;
      height: 22px;
    }

    .scroll-hint {
      bottom: var(--space-6);
    }

    .philosophy-text {
      font-size: var(--headline-md);
    }

    .manifesto-text {
      font-size: var(--headline-sm);
    }

    .article-link {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
